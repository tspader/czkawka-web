+pub(crate) fn connect_progress_json(progress_receiver: &Receiver<ProgressData>) {
+    let stderr = std::io::stderr();
+    while let Ok(p) = progress_receiver.recv() {
+        let mut out = stderr.lock();
+        let _ = writeln!(
+            out,
+            "{{\"event\":\"progress\",\"tool\":\"{:?}\",\"stage\":\"{:?}\",\"checking_method\":\"{:?}\",\"current_stage_idx\":{},\"max_stage_idx\":{},\"entries_checked\":{},\"entries_to_check\":{},\"bytes_checked\":{},\"bytes_to_check\":{}}}",
+            p.tool_type,
+            p.sstage,
+            p.checking_method,
+            p.current_stage_idx,
+            p.max_stage_idx,
+            p.entries_checked,
+            p.entries_to_check,
+            p.bytes_checked,
+            p.bytes_to_check,
+        );
+    }
+}
